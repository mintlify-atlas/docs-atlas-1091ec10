  "keyFeatures": [
    "AdaEvolve: Adaptive multi-island evolutionary search with UCB and paradigm breakthroughs",
    "EvoX: Self-evolving optimization that co-adapts solution generation and experience management",
    "200+ optimization benchmarks across math, systems, and programming domains",
    "Unified interface for implementing and comparing discovery algorithms",
    "Real-time monitoring dashboard with human feedback integration",
    "Multi-model LLM support with weighted sampling (OpenAI, Gemini, Anthropic, local models)",
    "Modular architecture with pluggable search algorithms and context builders",
    "Agentic mode for codebase-aware optimization"
  ],
  "publicApiSurface": [
    "run_discovery(evaluator, initial_program, model, iterations, search, config)",
    "discover_solution(evaluator, initial_solution, iterations, search, model)",
    "Runner(initial_program_path, evaluation_file, config, output_dir)",
    "DiscoveryResult(best_program, best_score, best_solution, metrics, output_dir)",
    "skydiscover-run [INITIAL_PROGRAM] EVALUATOR --search ALGORITHM --iterations N",
    "skydiscover-viewer CHECKPOINT_PATH",
    "ProgramDatabase.add(program, iteration)",
    "ProgramDatabase.sample(num_context_programs)",
    "DiscoveryController.run_discovery(start_iteration, max_iterations)"
  ]
